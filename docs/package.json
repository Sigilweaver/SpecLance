{
    "name": "speclance-docs",
    "version": "0.0.0",
    "private": true,
    "scripts": {
        "docusaurus": "docusaurus",
        "start": "docusaurus start --port 25818",
        "dev": "docusaurus start --port 25818",
        "build": "docusaurus build",
